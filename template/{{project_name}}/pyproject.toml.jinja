[project]
name = "{{project_name}}"
version = "{{version}}"
description = "{{project_description}}"
readme = "README.md"
requires-python = ">=3.12"
dependencies = [
    "alembic>=1.18.4",
    "fastapi[standard]>=0.134.0",
    "psycopg>=3.3.3",
    "sqlmodel>=0.0.37",
    "uvicorn[standard]>=0.41.0",
]
authors = [
    { name = "{{author_name}}", email = "{{author_email}}" }
]

[dependency-groups]
dev = [
    "coverage>=7.13.4",
    "grimp>=3.14",
    "httpx>=0.28.1",
    "pytest>=9.0.2",
]
